    "blue": (80, 80, 255),
    "yellow": (255, 255, 80),
    "cyan": (80, 255, 255),
    "magenta": (255, 80, 255),
    "white": (255, 255, 255),
    "black": (0, 0, 0),
    "gray": (160, 160, 160),
    "orange": (255, 165, 0),
    "purple": (160, 80, 255),
    "pink": (255, 180, 200),
    "brown": (160, 100, 50),
    "gold": (255, 215, 0),
    "silver": (192, 192, 192)
}

